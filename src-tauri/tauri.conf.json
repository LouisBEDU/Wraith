{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wraith",
  "version": "0.2.1",
  "identifier": "wraith",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wraith",
        "width": 1200,
        "height": 800,
        "minWidth": 500,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwNTdCODc5MDA4QTYxNzUKUldSMVlZb0FlYmhYa05Rd1Y5N1ZSTjZ3RWtlWFVMMksrQi9lVEFscVZZV2NkK3lQQlNiWUxPS2MK",
      "endpoints": [
        "https://github.com/LouisBEDU/Wraith/releases/latest/download/latest.json"
      ]
    }
  }
}
